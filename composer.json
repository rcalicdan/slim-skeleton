{
    "name": "rcalicdan/slim-skeleton",
    "description": "Slim 4 skeleton with PHP-DI, Blade, and Pest",
    "type": "project",
    "require": {
        "php": "^8.4",
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "php-di/php-di": "^7.1",
        "eftec/bladeone": "^4.19",
        "rcalicdan/config-loader": "^1.2",
        "rakit/validation": "^1.4",
        "odan/session": "^6.5"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.10",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Integrations\\": "integrations/"
        },
        "files": [
            "integrations/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "format": "./vendor/bin/pint",
        "analyze": "./vendor/bin/phpstan analyse"
    }
}
