{
    "name": "rcalicdan/slim-skeleton",
    "description": "Slim 4 skeleton with PHP-DI, Blade, and Pest",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "php-di/php-di": "^7.1",
        "eftec/bladeone": "^4.19",
        "rcalicdan/config-loader": "^1.2",
        "odan/session": "^6.5",
        "somnambulist/validation": "^1.13",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.10",
        "phpstan/phpstan": "^2.1",
        "zorac/phpstan-php-di": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Integrations\\": "integrations/"
        },
        "files": [
            "integrations/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "./vendor/bin/pest",
        "format": "./vendor/bin/pint",
        "analyze": "./vendor/bin/phpstan analyse"
    }
}